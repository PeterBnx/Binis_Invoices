{
  "name": "binis-invoices",
  "author": "Petros Binis",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "Desktop application for automating the process of invoice extraction for binis.gr",
  "scripts": {
    "dev": "npm-run-all --parallel dev:react dev:electron",
    "dev:react": "vite",
    "dev:electron": "npm run transpile:electron && cross-env NODE_ENV=development electron .",
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "publish": "electron-builder --publish always",
    "clean:electron": "rimraf dist-electron",
    "transpile:electron": "npm run clean:electron && tsc --project src/electron/tsconfig.json",
    "postinstall": "electron-builder install-app-deps",
    "dist:mac": "npm run transpile:electron && npm run build && electron-builder --mac --arm64",
    "dist:win": "npm run transpile:electron && npm run build && electron-builder --win --x64",
    "dist:linux": "npm run transpile:electron && npm run build && electron-builder --linux --x64",
    "dist": "npm run dist:win"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@tailwindcss/vite": "^4.1.11",
    "better-sqlite3": "^12.4.1",
    "electron-updater": "^6.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/cli": "^4.1.11",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.29",
    "cross-env": "^7.0.3",
    "electron": "^42.0.1",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^2.0.3",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.6.2",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "ws": "^8.18.3"
  },
  "repository": {
  "type": "git",
  "url": "https://github.com/PeterBnx/Binis_Invoices.git"
  },
  "extraResources": [
    {
      "from": "dist/ipc.exe",
      "to": "bin/ipc.exe"
    },
    {
      "from": "C:/Users/binis/AppData/Local/ms-playwright",
      "to": "bin/ms-playwright"
    }
  ],
  "build": {
    "appId": "com.peterbnx.binis-invoices",
    "publish": [
      {
        "provider": "github",
        "owner": "PeterBnx",
        "repo": "Binis_Invoices"
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}
