{
  "name": "binis-invoices",
  "author": "Petros Binis",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "Desktop application for automating the process of invoice extraction for binis.gr",
  "scripts": {
    "dev": "npm-run-all --parallel dev:react dev:electron",
    "dev:react": "vite",
    "dev:electron": "npm run transpile:electron && cross-env NODE_ENV=development electron .",
    "clean:dist": "rimraf dist",
    "clean:react": "rimraf dist-react",
    "clean:electron": "rimraf dist-electron",
    "clean:all": "rimraf dist dist-react dist-electron",
    "build": "npm run clean:react && tsc -b && vite build",
    "transpile:electron": "npm run clean:electron && tsc --project src/electron/tsconfig.json",
    "bundle:all": "pyinstaller --clean --onedir --noconsole --noconfirm --paths src/scripts src/scripts/ipc.py --distpath ./dist && npm run transpile:electron && npm run build && npx electron-builder --dir -c.directories.output=release",
    "publish": "electron-builder --publish always",
    "postinstall": "electron-builder install-app-deps",
    "dist:win": "npm run clean:all && npm run transpile:electron && npm run build && electron-builder --win --x64",
    "dist": "npm run dist:win"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/vite": "^4.1.11",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.25.0",
    "@tailwindcss/cli": "^4.1.11",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.29",
    "cross-env": "^7.0.3",
    "electron": "^42.0.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.6.2",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PeterBnx/Binis_Invoices.git"
  },
  "extraResources": [
    {
      "from": "dist/ipc/",
      "to": "bin/"
    },
    {
      "from": "data/",
      "to": "data/"
    },
    {
      "from": "ms-playwright/",
      "to": "bin/ms-playwright"
    }
  ],
  "build": {
    "appId": "com.peterbnx.binis-invoices",
    "productName": "Binis Invoices",
    "files": [
      "dist-electron/**/*",
      "dist-react/**/*",
      "package.json",
      "src/ui/assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "icon": "src/ui/assets/binis_logo.ico"
    },
    "mac": {
      "icon": "src/ui/assets/binis_logo.icns"
    },
    "linux": {
      "icon": "src/ui/assets/binis_logo.png"
    },
    "extraResources": [
      {
        "from": "dist/ipc/",
        "to": "bin/"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "PeterBnx",
        "repo": "Binis_Invoices"
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
